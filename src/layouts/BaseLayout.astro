---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
}

const {
  title = 'florin.log — notes on engineering',
  description = 'Essays on Angular, NestJS, microservices and the practice of software engineering.',
  wide = false,
} = Astro.props;

const path = Astro.url.pathname;
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="florin.log" href="/rss.xml" />

    <!-- Google tag (gtag.js) -->
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-KQ1DVK88T5"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-KQ1DVK88T5');
    </script>
  </head>
  <body>
    <div class:list={['shell', wide && 'shell-wide']}>
      <header class="nav">
        <a class="wordmark" href="/">florin.log</a>
        <nav aria-label="Primary">
          <ul>
            <li><a href="/" class={path === '/' ? 'active' : ''}>Writing</a></li>
            <li><a href="/about" class={path.startsWith('/about') ? 'active' : ''}>About</a></li>
            <li><a href="/rss.xml">RSS</a></li>
          </ul>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="colophon">
        <div>© {year} Florin Ciocîrlan</div>
        <div>
          <a href="https://github.com/FlorinCiocirlan" target="_blank" rel="noopener">GitHub</a>
          &nbsp;·&nbsp;
          <a href="https://www.linkedin.com/in/florin-ciocirlan-angular/" target="_blank" rel="noopener">LinkedIn</a>
          &nbsp;·&nbsp;
          <a href="/rss.xml">RSS</a>
        </div>
      </footer>
    </div>
  </body>
</html>
