---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  readingTime?: string;
  tableOfContents?: Heading[];
  relatedPosts?: CollectionEntry<'posts'>[];
  previousPost?: CollectionEntry<'posts'>;
  nextPost?: CollectionEntry<'posts'>;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  readingTime,
  tableOfContents = [],
  relatedPosts = [],
  previousPost,
  nextPost,
} = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---
<BaseLayout title={`${title} — florin.log`} description={description} wide>
  <div class="article-shell">
    <article class="article">
      <div class="crumb">
        <a href="/">← All writing</a>
      </div>

      <header class="post-head">
        <h1>{title}</h1>
        <p class="desc">{description}</p>
        <div class="meta">
          <span>{fmt(pubDate)}</span>
          {readingTime && <><span class="dot">·</span><span>{readingTime}</span></>}
          {updatedDate && <><span class="dot">·</span><span>Updated {fmt(updatedDate)}</span></>}
        </div>
      </header>

      <aside class="article-summary" aria-label="What you will get from this article">
        <strong>In this post</strong>
        <p>{description}</p>
      </aside>

      {tableOfContents.length >= 3 && (
        <nav class="toc toc-inline" aria-label="Table of contents">
          <strong>Contents</strong>
          <ol>
            {tableOfContents.map((heading) => (
              <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
            ))}
          </ol>
        </nav>
      )}

      <div class="prose">
        <slot />
      </div>

      <footer class="post-foot">
        {relatedPosts.length > 0 && (
          <section class="read-next" aria-labelledby="read-next-title">
            <h2 id="read-next-title">Read next</h2>
            <div class="read-next-grid">
              {relatedPosts.map((post) => (
                <a href={`/posts/${post.id}/`}>
                  <span>{post.data.title}</span>
                  <small>{post.data.description}</small>
                </a>
              ))}
            </div>
          </section>
        )}

        {(previousPost || nextPost) && (
          <nav class="post-pager" aria-label="Post navigation">
            {previousPost ? (
              <a href={`/posts/${previousPost.id}/`}>
                <small>Previous</small>
                <span>{previousPost.data.title}</span>
              </a>
            ) : <span></span>}
            {nextPost ? (
              <a href={`/posts/${nextPost.id}/`}>
                <small>Next</small>
                <span>{nextPost.data.title}</span>
              </a>
            ) : <span></span>}
          </nav>
        )}

        <div class="foot-meta">
          <a href="/">← All writing</a>
          {tags.length > 0 && (
            <span class="tag-list">
              {tags.map((tag) => (
                <a href={`/tags/${tag}/`}>#{tag}</a>
              ))}
            </span>
          )}
        </div>
      </footer>
    </article>

    {tableOfContents.length >= 3 && (
      <aside class="side-toc" aria-label="Sticky table of contents">
        <nav>
          <strong>Contents</strong>
          <ol>
            {tableOfContents.map((heading) => (
              <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
            ))}
          </ol>
        </nav>
      </aside>
    )}
  </div>
</BaseLayout>
