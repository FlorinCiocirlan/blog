---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  readingTime?: string;
}

const { title, description, pubDate, updatedDate, tags = [], readingTime } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---
<BaseLayout title={`${title} — florin.log`} description={description}>
  <article class="article">
    <div class="crumb">
      <a href="/">← All writing</a>
    </div>

    <header class="post-head">
      <h1>{title}</h1>
      <p class="desc">{description}</p>
      <div class="meta">
        <span>{fmt(pubDate)}</span>
        {readingTime && <><span class="dot">·</span><span>{readingTime}</span></>}
        {updatedDate && <><span class="dot">·</span><span>Updated {fmt(updatedDate)}</span></>}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    <footer class="post-foot">
      <a href="/">← All writing</a>
      {tags.length > 0 && <span>{tags.map((t) => `#${t}`).join('  ·  ')}</span>}
    </footer>
  </article>
</BaseLayout>
