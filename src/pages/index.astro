---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const featured = all.slice(0, 3);
---
<BaseLayout>
  <section class="intro">
    <h1>Florin Ciocîrlan</h1>
    <p>
      Software engineer. I write about Angular, NestJS, microservices, and the
      practice of building software that holds up.
    </p>
  </section>

  {featured.length > 0 && (
    <section class="start-here" aria-labelledby="start-here-title">
      <div>
        <h2 id="start-here-title">Start here</h2>
        <p>
          Practical notes from real product engineering: frontend architecture,
          platform abstractions, developer experience, and systems that reduce delivery cost.
        </p>
      </div>
      <ul>
        {featured.map((post) => (
          <li>
            <a href={`/posts/${post.id}/`}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section>
    <div class="section-head">
      <h2>Writing</h2>
      <span class="count">{all.length} posts</span>
    </div>

    <ul class="posts">
      {all.map((post) => (
        <li class="post-row">
          <div class="body">
            <h3><a href={`/posts/${post.id}/`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
          </div>
          <div class="date">{fmt(post.data.pubDate)}</div>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
