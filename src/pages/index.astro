---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<BaseLayout>
  <section class="intro">
    <h1>Florin Ciocîrlan</h1>
    <p>
      Software engineer. I write about Angular, NestJS, microservices, and the
      practice of building software that holds up.
    </p>
  </section>

  <section>
    <div class="section-head">
      <h2>Writing</h2>
      <span class="count">{all.length} posts</span>
    </div>

    <ul class="posts">
      {all.map((post) => (
        <li class="post-row">
          <div class="body">
            <h3><a href={`/posts/${post.id}/`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
          </div>
          <div class="date">{fmt(post.data.pubDate)}</div>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
